<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text-3xl mb-5">Upload File</h3>
        <form autocomplete="off" action="/upload" method="post" enctype="multipart/form-data">       <%  //post is here so that password should not be seen in url %>
            <input type="file" name="image">
            <input class="px-5 py-2 rounded-md bg-yellow-800" type="Submit" value="Submit file">

        </form>
    </div>
</body>
</html>
